{
  "expo": {
    "name": "Gold Penny",
    "description": "Gold Penny is a daily strategy game from Penny Float.",
    "slug": "gold-penny-expo",
    "scheme": "goldpenny",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "android": {
      "package": "com.pennyfloat.goldpenny",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/android-icon-foreground.png",
        "backgroundImage": "./src/assets/images/android-icon-background.png",
        "monochromeImage": "./src/assets/images/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "goldpenny"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.pennyfloat.goldpenny",
      "buildNumber": "1.0.1",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "updates": {
      "url": "https://u.expo.dev/cd780971-b503-487e-89dc-6984f42eba69",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cd780971-b503-487e-89dc-6984f42eba69"
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "owner": "nntpress"
  }
}
